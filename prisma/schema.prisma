generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id   String @id
  name String

  orders   Order[]
  invoices Invoice[]
  payments Payment[]
}

model Order {
  id             String @id
  customerId     String
  createdAt      String
  totalAmount    Float
  deliveryStatus String

  metadata String?

  customer   Customer   @relation(fields: [customerId], references: [id])
  items      OrderItem[]
  deliveries Delivery[]
}

model Product {
  id   String @id
  name String

  orderItems OrderItem[]
}

model JournalEntry {
  id        String @id
  invoiceId String
  amount    Float
  createdAt String

  metadata String?

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Delivery {
  id        String @id
  orderId   String?
  createdAt String
  status    String
  metadata String?

  order Order? @relation(fields: [orderId], references: [id])
}

model OrderItem {
  id        String @id
  orderId   String
  productId String
  quantity  Float
  netAmount Float

  metadata String?

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Invoice {
  id                 String @id
  customerId         String
  accountingDocument String
  totalAmount        Float
  createdAt          String

  metadata String?

  customer       Customer      @relation(fields: [customerId], references: [id])
  journalEntries JournalEntry[]
}

model Payment {
  id         String @id
  customerId String
  amount     Float
  createdAt  String

  metadata String?

  customer Customer @relation(fields: [customerId], references: [id])
}